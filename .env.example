# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers → Copy URI
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/maswrite?retryWrites=true&w=majority

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Must match the URL your app runs on (no trailing slash)
NEXTAUTH_URL=http://localhost:3000
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your-random-32-char-secret-here

# ─── Manual JWT (credentials login) ──────────────────────────────────────────
# Used to sign/verify your own JWT cookies (separate from NextAuth secret)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_AUTH_SECRET=your-another-random-32-char-secret-here

# ─── App URL (used in password-reset email links) ─────────────────────────────
APP_URL=http://localhost:3000

# ─── OAuth — Google ───────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── OAuth — GitHub ───────────────────────────────────────────────────────────
# Get from: https://github.com/settings/developers → New OAuth App
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Email — Resend ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Free tier: 100 emails/day, 3000/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Web Push / VAPID (future use) ────────────────────────────────────────────
# Generate keys by running: pnpm tsx scripts/generateVapidKeys.ts
# VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VAPID_SUBJECT=mailto:you@maswrite.com
