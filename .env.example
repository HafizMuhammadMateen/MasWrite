# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=''
# /maswrite?retryWrites=true&w=majority

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=''
NEXTAUTH_SECRET=''

# ─── Manual JWT (credentials login) ──────────────────────────────────────────
# Used to sign/verify your own JWT cookies (separate from NextAuth secret)
JWT_AUTH_SECRET=''

# ─── App URL (used in password-reset email links) ─────────────────────────────
APP_URL=''

# ─── OAuth — Google ───────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=''
GOOGLE_CLIENT_SECRET=''

# ─── OAuth — GitHub ───────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=''
GITHUB_CLIENT_SECRET=''

# ─── Email — Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=''

# ─── Web Push / VAPID (future use) ────────────────────────────────────────────
# Generate keys by running: pnpm tsx scripts/generateVapidKeys.ts
# VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VAPID_SUBJECT=mailto:you@maswrite.com
